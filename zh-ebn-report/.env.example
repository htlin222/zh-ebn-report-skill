# LLM backend — choose ONE path
# Default (recommended): go through your Claude Code subscription, no API key
#   Requires `claude` CLI on PATH. Get it at https://claude.com/claude-code
LLM_BACKEND=claude_code
# Alternatives:
#   LLM_BACKEND=anthropic    # direct Anthropic SDK, requires ANTHROPIC_API_KEY
#   LLM_BACKEND=auto         # use CLI when available, else SDK

# Optional: override which `claude` binary is used (useful for alt installs)
# CLAUDE_BIN=/Users/you/.local/bin/claude

# Only needed when LLM_BACKEND=anthropic
ANTHROPIC_API_KEY=
# Or point at an Anthropic-schema-compatible proxy:
LLM_API_BASE=
LLM_API_KEY=
LLM_MODEL=

# Literature databases (PubMed/Scopus/Embase — public/free or paid)
PUBMED_API_KEY=
SCOPUS_API_KEY=
SCOPUS_INST_TOKEN=
EMBASE_API_KEY=
EMBASE_INST_TOKEN=
EMBASE_AUTH_TOKEN=

# DOI validation & OA status (free, polite pool)
CROSSREF_MAILTO=your-email@example.com
UNPAYWALL_EMAIL=your-email@example.com

# Zotero bibliography management (optional, for future use)
ZOTERO_API_KEY=
ZOTERO_LIBRARY_TYPE=user
ZOTERO_LIBRARY_ID=
ZOTERO_COLLECTION_KEY=

# Pipeline behavior
DEFAULT_TARGET_YEAR_RANGE=5
MAX_PARALLEL_CASP_APPRAISERS=8
MAX_PARALLEL_SECTION_WRITERS=6
